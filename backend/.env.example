PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=
TRUST_PROXY_HOPS=

# Generate three different random values of at least 32 bytes for production.
JWT_SECRET=
AUDIT_HASH_SECRET=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=vbee-aivoice
JWT_AUDIENCE=vbee-web
SECURITY_AUDIT_RETENTION_DAYS=180
# URL HTTPS công khai của backend, dùng để Sonix tải file lớn qua file_url.
PUBLIC_BACKEND_URL=
PROVIDER_FILE_SIGNING_SECRET=
PROVIDER_FILE_URL_TTL_SECONDS=7200

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=golden_voice
DB_USER=postgres
DB_PASSWORD=
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_SSL_CA=
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECT_TIMEOUT_MS=10000
DB_STATEMENT_TIMEOUT_MS=30000

# Google OAuth 2.0 - không bắt buộc nếu dùng email/password login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# SMTP gửi email quên mật khẩu. Khi chưa cấu hình ở local, API trả resetUrl để thử nghiệm.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Vbee AIVoice <no-reply@vbee.local>
PASSWORD_RESET_TTL_MINUTES=30

# Provider chuyển giọng nói thành văn bản: vbee, sonix, deepgram hoặc assemblyai
TRANSCRIPTION_PROVIDER=deepgram
MAX_UPLOAD_MB=200
SYNC_API_MAX_MB=25
ALLOW_SYNC_PUBLIC_API=false
UPLOAD_STAGING_DIR=
MALWARE_SCAN_REQUIRED=false
CLAMAV_SCAN_COMMAND=
CLAMAV_DATABASE_DIR=
CLAMAV_SCAN_MODE=clamscan
CLAMAV_SCAN_CONFIG=
MALWARE_SCAN_TIMEOUT_MS=120000
# Production multiple-server setup: mount the same persistent volume on every API/worker node.
UPLOADS_DIR=

# Persistent PostgreSQL job queue. Upload returns immediately; this worker processes jobs in the background.
# Local can run both in one process. Production API: false; dedicated `npm run worker`: true.
RUN_TRANSCRIPTION_WORKER=true
TRANSCRIPTION_QUEUE_CONCURRENCY=2
TRANSCRIPTION_QUEUE_POLL_MS=1000
TRANSCRIPTION_QUEUE_STALE_SECONDS=1200
FREE_AUDIO_RETENTION_DAYS=7
STANDARD_AUDIO_RETENTION_DAYS=90
SPECIAL_AUDIO_RETENTION_DAYS=365
BUSINESS_AUDIO_RETENTION_DAYS=365
MAX_PENDING_JOBS_PER_USER=5
MAX_PENDING_JOBS_GLOBAL=500

# Optional vocal isolation for Upload mode "Bài hát / nhạc nền".
AUDIO_PREPROCESSING_ENABLED=true
AUDIO_PREPROCESSING_TIMEOUT_MS=180000
FFMPEG_PATH=
YOUTUBE_IMPORT_ENABLED=true
YT_DLP_PATH=
# File cookies.txt của tài khoản dịch vụ được phép truy cập video. Không dùng cookies trình duyệt cá nhân trên server.
YOUTUBE_COOKIES_FILE=
YOUTUBE_METADATA_TIMEOUT_MS=45000
YOUTUBE_DOWNLOAD_TIMEOUT_MS=600000
SONG_AUDIO_FILTER=highpass=f=120,lowpass=f=8000,afftdn=nf=-25,dynaudnorm=f=150:g=15,acompressor=threshold=-20dB:ratio=3:attack=5:release=120,loudnorm=I=-16:LRA=11:TP=-1.5
# auto = try Python Demucs first, then fall back to the ffmpeg filter.
DEMUCS_ENABLED=auto
DEMUCS_PYTHON_PATH=python
DEMUCS_COMMAND=
DEMUCS_MODEL=htdemucs
DEMUCS_TIMEOUT_MS=600000

# Plan / quota controls
FREE_PLAN_SECONDS=1800
FREE_MAX_UPLOAD_MB=50
FREE_MAX_RECORD_SECONDS=600
FREE_MAX_FILE_SECONDS=1800
REFERRAL_REWARD_SECONDS=6000
REFERRAL_REWARD_VALID_DAYS=90
REFERRAL_CLAIM_WINDOW_MINUTES=30
STANDARD_MONTHLY_SECONDS=18000
STANDARD_YEARLY_SECONDS=216000
STANDARD_MAX_UPLOAD_MB=200
STANDARD_MAX_RECORD_SECONDS=3600
STANDARD_MAX_FILE_SECONDS=7200
SPECIAL_MONTHLY_SECONDS=72000
SPECIAL_YEARLY_SECONDS=864000
SPECIAL_MAX_UPLOAD_MB=1024
SPECIAL_MAX_RECORD_SECONDS=7200
SPECIAL_MAX_FILE_SECONDS=14400
BUSINESS_MONTHLY_SECONDS=144000
BUSINESS_YEARLY_SECONDS=1728000
BUSINESS_MAX_UPLOAD_MB=2048
BUSINESS_MAX_RECORD_SECONDS=28800
BUSINESS_MAX_FILE_SECONDS=28800
DEFAULT_QUOTA_ALERT_SECONDS=300

# Billing / checkout controls
BILLING_ORDER_TTL_MINUTES=30
STANDARD_MONTHLY_PRICE_VND=150000
STANDARD_YEARLY_PRICE_VND=1650000
SPECIAL_MONTHLY_PRICE_VND=449000
SPECIAL_YEARLY_PRICE_VND=4939000
BUSINESS_MONTHLY_PRICE_VND=799000
BUSINESS_YEARLY_PRICE_VND=8789000
TOPUP_1H_PRICE_VND=39000
TOPUP_3H_PRICE_VND=117000
TOPUP_5H_PRICE_VND=195000
TOPUP_10H_PRICE_VND=390000
TOPUP_20H_PRICE_VND=780000
TOPUP_50H_PRICE_VND=1950000
TOPUP_100H_PRICE_VND=3900000
# PayOS (by Casso): create a channel at my.payos.vn, then configure its public webhook URL.
PAYMENT_PROVIDER=payos
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_API_BASE_URL=https://api-merchant.payos.vn
PAYOS_STATUS_CHECK_INTERVAL_SECONDS=8
PAYOS_REQUEST_TIMEOUT_MS=15000
# Example: https://api.your-domain.vn/api/billing/payos/webhook
PAYOS_WEBHOOK_URL=
# Keep false in production. Demo activation never verifies a bank transfer.
ENABLE_DEMO_PAYMENTS=false
# Chỉ bật khi cần endpoint demo cũ POST /api/quota/upgrade, production nên để false.
ENABLE_DEV_QUOTA_UPGRADE=false
CREATE_DEMO_USER=false

# Sonix.ai API - lấy tại https://my.sonix.ai/api
# Sonix dùng Bearer API key, upload /v1/media, poll status rồi lấy transcript.json.
SONIX_API_KEY=your_sonix_api_key_here
SONIX_LANGUAGE=vi
SONIX_POLL_INTERVAL_MS=5000
SONIX_TIMEOUT_MS=1800000
SONIX_CALLBACK_URL=
SONIX_CALLBACK_SECRET=
MEDIA_PROBE_TIMEOUT_MS=120000
PROVIDER_REQUEST_TIMEOUT_MS=1800000

# Deepgram API - dùng khi TRANSCRIPTION_PROVIDER=deepgram
# Deepgram nhận file trực tiếp qua POST https://api.deepgram.com/v1/listen
DEEPGRAM_API_KEY=your_deepgram_api_key_here
DEEPGRAM_API_BASE_URL=https://api.deepgram.com/v1
DEEPGRAM_MODEL=nova-3
DEEPGRAM_LANGUAGE=vi
DEEPGRAM_DETECT_LANGUAGE=false
DEEPGRAM_SMART_FORMAT=true
DEEPGRAM_PUNCTUATE=true
DEEPGRAM_PARAGRAPHS=true
DEEPGRAM_UTTERANCES=true
DEEPGRAM_KEYWORDS=
DEEPGRAM_DIARIZE_MODEL=

# Vbee STT API - dùng khi TRANSCRIPTION_PROVIDER=vbee
# Điền endpoint/path đúng theo tài liệu STT của Vbee hoặc cấu hình trong Admin CMS.
VBEE_API_KEY=your_vbee_stt_api_key_here
# Nếu bạn đặt key theo cURL mẫu, backend cũng tự fallback sang AIMP_API_KEY.
AIMP_API_KEY=
VBEE_API_BASE_URL=https://uat-api.vbeelabs.ai
VBEE_AUTH_HEADER=Authorization
VBEE_AUTH_SCHEME=Bearer
VBEE_TRANSCRIBE_PATH=/api/v1/audio/transcriptions
VBEE_MODEL=vbee-stt
VBEE_MODEL_FIELD=model
VBEE_RESPONSE_FORMAT=json
VBEE_RESPONSE_FORMAT_FIELD=response_format
VBEE_RESULT_PATH_TEMPLATE=/v1/transcribe/{id}
VBEE_LANGUAGE=vi
VBEE_FILE_FIELD=file
VBEE_LANGUAGE_FIELD=
VBEE_FILENAME_FIELD=
VBEE_SPEAKER_LABELS_FIELD=
VBEE_KEYWORDS_FIELD=keywords
VBEE_ID_PATH=
VBEE_STATUS_PATH=
VBEE_TEXT_PATH=
VBEE_WORDS_PATH=
VBEE_DURATION_PATH=
VBEE_POLL_INTERVAL_MS=5000
VBEE_TIMEOUT_MS=1800000

# Dịch transcript sang ngôn ngữ khác
# Khuyến nghị: Google Cloud Translation cho dịch nhiều ngôn ngữ ổn định hơn.
TRANSLATION_PROVIDER=auto
GOOGLE_TRANSLATE_API_URL=https://translation.googleapis.com/language/translate/v2
GOOGLE_TRANSLATE_API_KEY=
TRANSLATION_REQUEST_TIMEOUT_MS=30000
MAX_TRANSLATION_CHARS=200000

# Fallback: LibreTranslate compatible API hoặc MyMemory public API
LIBRETRANSLATE_API_URL=https://libretranslate.com
LIBRETRANSLATE_API_KEY=
MYMEMORY_API_URL=https://api.mymemory.translated.net
MYMEMORY_EMAIL=

# AssemblyAI - dùng khi TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

JWT_SECRET=change_this_to_a_very_long_random_secret_string

# Admin CMS seed account. Created/updated during backend initDb.
ADMIN_SEED_EMAIL=superadmin@vbee.local
ADMIN_SEED_PASSWORD=admin123
ADMIN_SEED_FIRST_NAME=Vbee
ADMIN_SEED_LAST_NAME=Admin
ASSEMBLYAI_API_KEY=
ASSEMBLYAI_TRANSLATION_ENABLED=true
